{
  "info": {
    "name": "Wilson",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Wilson API collection with chat, model server health checks, and tool metadata/history endpoints."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:9400" },
    { "key": "accessKey", "value": "wilsonadmin" },
    { "key": "token", "value": "wilsonadmin" },
    { "key": "runnerId", "value": "local-ollama" },
    { "key": "modelName", "value": "llama3.2" },
    { "key": "toolName", "value": "read_file" },
    { "key": "toolRunId", "value": "toolrun_000000000000000000000000" },
    { "key": "conversationId", "value": "conv_000000000000000000000000" },
    { "key": "requestHistoryId", "value": "req_000000000000000000000000" },
    { "key": "tenantId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Create Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1.0/auth/token",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "auth", "token" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessKey\": \"{{accessKey}}\"\n}"
            }
          }
        },
        {
          "name": "Current Principal",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/me",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "me" ]
            }
          }
        }
      ]
    },
    {
      "name": "Model Servers",
      "item": [
        {
          "name": "List Model Servers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/model-runners?pageNumber=1&pageSize=100",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "model-runners" ],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "List Model Server Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/model-runners/health",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "model-runners", "health" ]
            }
          }
        },
        {
          "name": "Get Model Server Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/model-runners/{{runnerId}}/health",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "model-runners", "{{runnerId}}", "health" ]
            }
          }
        },
        {
          "name": "Pull Ollama Model",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/model-runners/{{runnerId}}/pull",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "model-runners", "{{runnerId}}", "pull" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{modelName}}\"\n}"
            }
          }
        },
        {
          "name": "Load Ollama Model",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/model-runners/{{runnerId}}/load",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "model-runners", "{{runnerId}}", "load" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{modelName}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Non-Streaming Chat With Tools",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/chat",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "chat" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"runnerId\": \"{{runnerId}}\",\n  \"model\": \"{{modelName}}\",\n  \"prompt\": \"Read README.md\",\n  \"toolsEnabled\": true,\n  \"approvalPolicy\": \"auto\",\n  \"toolNames\": [\"read_file\"],\n  \"settings\": {\n    \"temperature\": 0,\n    \"topP\": 1,\n    \"maxTokens\": 512\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tools",
      "item": [
        {
          "name": "List Tools",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/tools",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "tools" ]
            }
          }
        },
        {
          "name": "Get Tool",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/tools/{{toolName}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "tools", "{{toolName}}" ]
            }
          }
        },
        {
          "name": "Validate Tool Policy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/tools/validate",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "tools", "validate" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tools\": {\n    \"enabled\": true,\n    \"defaultApprovalPolicy\": \"auto\",\n    \"workingDirectory\": \"C:\\\\Code\\\\Wilson\",\n    \"allowedRoots\": [\"C:\\\\Code\\\\Wilson\"]\n  }\n}"
            }
          }
        },
        {
          "name": "Test Tool Readiness",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/tools/test",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "tools", "test" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"runnerId\": \"{{runnerId}}\",\n  \"tools\": {\n    \"enabled\": true,\n    \"defaultApprovalPolicy\": \"auto\",\n    \"workingDirectory\": \"C:\\\\Code\\\\Wilson\",\n    \"allowedRoots\": [\"C:\\\\Code\\\\Wilson\"]\n  }\n}"
            }
          }
        },
        {
          "name": "Get Tool Run",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/tool-runs/{{toolRunId}}?tenantId={{tenantId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "tool-runs", "{{toolRunId}}" ],
              "query": [
                { "key": "tenantId", "value": "{{tenantId}}" }
              ]
            }
          }
        },
        {
          "name": "List Conversation Tool Calls",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/conversations/{{conversationId}}/tool-calls?pageNumber=1&pageSize=100",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "conversations", "{{conversationId}}", "tool-calls" ],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "List Request History Tool Calls",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/request-history/{{requestHistoryId}}/tool-calls?pageNumber=1&pageSize=100&tenantId={{tenantId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "request-history", "{{requestHistoryId}}", "tool-calls" ],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "100" },
                { "key": "tenantId", "value": "{{tenantId}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Service",
      "item": [
        {
          "name": "Service Health",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{baseUrl}}/v1.0/api/health",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1.0", "api", "health" ]
            }
          }
        },
        {
          "name": "OpenAPI",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{baseUrl}}/openapi.json",
              "host": [ "{{baseUrl}}" ],
              "path": [ "openapi.json" ]
            }
          }
        }
      ]
    }
  ]
}
